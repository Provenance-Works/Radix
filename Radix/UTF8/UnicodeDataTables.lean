abbrev CodepointRange := Nat × Nat

private def inCodepointRanges (value : Nat) : List CodepointRange → Bool
  | [] => false
  | (startValue, endValue) :: rest =>
    (startValue ≤ value && value ≤ endValue) || inCodepointRanges value rest

